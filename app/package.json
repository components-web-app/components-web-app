    "@nuxt/image": "^2.0.0",
    "@nuxtjs/sitemap": "^8.0.15",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "@vite-pwa/nuxt": "^1.1.1",
    "nuxt": "4.4.4",
    "nuxt-svgo": "^5.3.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "4.0.0-alpha.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
